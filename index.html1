// ================================================
// DRIVE
// ================================================
let driveToken = null, driveTokenExpiry = 0, driveDataCache = {};

async function getDriveToken() {
  if (driveToken && Date.now() < driveTokenExpiry - 60000) return driveToken;
  const creds = DRIVE_CONFIG.credentials;
  const now = Math.floor(Date.now() / 1000);
  const header = btoa(JSON.stringify({alg:'RS256',typ:'JWT'})).replace(/=/g,'').replace(/\+/g,'-').replace(/\//g,'_');
  const claim = btoa(JSON.stringify({iss:creds.client_email,scope:'https://www.googleapis.com/auth/drive.readonly',aud:creds.token_uri,exp:now+3600,iat:now})).replace(/=/g,'').replace(/\+/g,'-').replace(/\//g,'_');
  const sigInput = header + '.' + claim;
  const pemKey = creds.private_key.replace('-----BEGIN PRIVATE KEY-----','').replace('-----END PRIVATE KEY-----','').replace(/\n/g,'');
  const binaryKey = Uint8Array.from(atob(pemKey), c => c.charCodeAt(0));
  const cryptoKey = await crypto.subtle.importKey('pkcs8', binaryKey.buffer, {name:'RSASSA-PKCS1-v1_5',hash:'SHA-256'}, false, ['sign']);
  const sigBytes = await crypto.subtle.sign('RSASSA-PKCS1-v1_5', cryptoKey, new TextEncoder().encode(sigInput));
  const sig = btoa(String.fromCharCode(...new Uint8Array(sigBytes))).replace(/=/g,'').replace(/\+/g,'-').replace(/\//g,'_');
  const jwt = sigInput + '.' + sig;
  const resp = await fetch('https://oauth2.googleapis.com/token', {method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:`grant_type=urn%3Aietf%3Aparams%3Aoauth%3Agrant-type%3Ajwt-bearer&assertion=${jwt}`});
  const data = await resp.json();
  if (!data.access_token) throw new Error(data.error_description || 'Token error');
  driveToken = data.access_token;
  driveTokenExpiry = Date.now() + (data.expires_in || 3600) * 1000;
  return driveToken;
}

async function loadDriveData() {
  if (!currentAgent) return;
  const folder = DRIVE_CONFIG.folders[currentAgent.id];
  if (!folder) return;
  const btn = document.getElementById('drive-load-btn');
  const status = document.getElementById('drive-status');
  btn.disabled = true; btn.textContent = '⏳ Загрузка...';
  try {
    const token = await getDriveToken();
    const url = `https://www.googleapis.com/drive/v3/files?q='${folder.id}'+in+parents+and+trashed=false&orderBy=modifiedTime+desc&fields=files(id,name,mimeType)&pageSize=10`;
    const resp = await fetch(url, {headers:{Authorization:'Bearer '+token}});
    const data = await resp.json();
    const files = data.files || [];
    if (!files.length) { status.textContent = 'Папка пуста'; btn.disabled = false; btn.textContent = '↓ Загрузить данные'; return; }
    let combined = '', names = [];
    for (const file of files) {
      try {
        const isSheet = file.mimeType === 'application/vnd.google-apps.spreadsheet';
        const fileUrl = isSheet
          ? `https://www.googleapis.com/drive/v3/files/${file.id}/export?mimeType=text/csv`
          : `https://www.googleapis.com/drive/v3/files/${file.id}?alt=media`;
        const fr = await fetch(fileUrl, {headers:{Authorization:'Bearer '+token}});
        const text = await fr.text();
        combined += `\n\n=== ${file.name} ===\n${text.substring(0, 3000)}`;
        names.push(file.name);
      } catch(e) { names.push(file.name + ' ⚠'); }
    }
    driveDataCache[currentAgent.id] = {text: combined, filename: names.join(', '), loaded: new Date().toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit'})};
    const container = document.getElementById('messages');
    const div = document.createElement('div');
    div.className = 'msg drive-msg';
    div.innerHTML = `📂 <b>Загружено: ${names.length} файлов</b><br>${names.join(' · ')}<br><span style="color:var(--green)">Данные доступны агенту.</span>`;
    container.appendChild(div); container.scrollTop = container.scrollHeight;
    btn.textContent = '✓ Обновить';
    status.textContent = `${names.length} файлов`;
  } catch(e) {
    status.textContent = '⚠ ' + e.message;
    btn.textContent = '↓ Попробовать снова';
  }
  btn.disabled = false;
}

function getDriveContext() {
  if (!currentAgent) return '';
  const cache = driveDataCache[currentAgent.id];
  if (!cache) return '';
  return `\n\n---\nДАННЫЕ ИЗ GOOGLE DRIVE (${cache.filename}, ${cache.loaded}):\n${cache.text.substring(0,6000)}\n---`;
}

function updateDriveBar() {
  const bar = document.getElementById('drive-bar');
  if (!currentAgent || !DRIVE_CONFIG.folders[currentAgent.id]) { bar.classList.remove('visible'); return; }
  bar.classList.add('visible');
  document.getElementById('drive-bar-label').textContent = DRIVE_CONFIG.folders[currentAgent.id].label;
  const cache = driveDataCache[currentAgent.id];
  document.getElementById('drive-status').textContent = cache ? cache.filename + ' · ' + cache.loaded : 'Не загружено';
  document.getElementById('drive-load-btn').textContent = cache ? '↓ Обновить' : '↓ Загрузить данные';
  document.getElementById('drive-load-btn').disabled = false;
}

// ================================================
// RUNWAY VIDEO GENERATION
// ================================================
async function generateRunwayVideo() {
  const prompt = document.getElementById('runway-prompt').value.trim();
  if (!prompt) { alert('Введи описание сцены для видео'); return; }

  const btn = document.getElementById('runway-btn');
  const status = document.getElementById('runway-status');
  const result = document.getElementById('runway-result');

  btn.disabled = true;
  status.textContent = '⏳ отправляю запрос...';
  result.classList.remove('visible');

  // Add progress message to chat
  const container = document.getElementById('messages');
  const progressDiv = document.createElement('div');
  progressDiv.className = 'msg video-msg';
  progressDiv.id = 'runway-progress-msg';
  progressDiv.innerHTML = `🎬 <b>Генерация видео запущена</b><br><span style="color:var(--text-dim)">Промпт: ${escHtml(prompt.substring(0,100))}...</span><br><span id="runway-progress-text" style="color:var(--runway)">Инициализация...</span>`;
  container.appendChild(progressDiv);
  container.scrollTop = container.scrollHeight;

  try {
    // Step 1: Create generation task
    const createResp = await fetch(`${RUNWAY_PROXY}/v1/text_to_video`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${RUNWAY_API_KEY}`,
        'X-Runway-Version': '2024-11-06'
      },
      body: JSON.stringify({
        promptText: prompt,
        model: 'gen4_turbo',
        ratio: '720:1280',
        duration: 5
      })
    });

    const createData = await createResp.json();
    if (createData.error || !createData.id) {
      throw new Error(createData.message || createData.error || 'Ошибка создания задачи');
    }

    const taskId = createData.id;
    setProgress(`Задача создана: ${taskId.slice(0,8)}... Ожидаю результат`);
    status.textContent = `⏳ обработка...`;

    // Step 2: Poll for result
    let videoUrl = null;
    for (let attempt = 0; attempt < 60; attempt++) {
      await new Promise(r => setTimeout(r, 5000));

      const pollResp = await fetch(`${RUNWAY_PROXY}/v1/tasks/${taskId}`, {
        headers: {
          'Authorization': `Bearer ${RUNWAY_API_KEY}`,
          'X-Runway-Version': '2024-11-06'
        }
      });

      const pollData = await pollResp.json();
      const elapsed = (attempt + 1) * 5;
      setProgress(`Статус: ${pollData.status} · ${elapsed}с прошло`);

      if (pollData.status === 'SUCCEEDED' && pollData.output?.[0]) {
        videoUrl = pollData.output[0];
        break;
      } else if (pollData.status === 'FAILED') {
        throw new Error('Runway не смог создать видео: ' + (pollData.failure || 'неизвестная ошибка'));
      }
    }

    if (!videoUrl) throw new Error('Превышено время ожидания (5 минут)');

    // Step 3: Show result
    const videoEl = document.getElementById('runway-video');
    const downloadEl = document.getElementById('runway-download');
    videoEl.src = videoUrl;
    downloadEl.href = videoUrl;
    result.classList.add('visible');
    status.textContent = '✅ готово!';

    // Update progress message with video
    const pm = document.getElementById('runway-progress-msg');
    if (pm) {
      pm.innerHTML = `🎬 <b>Видео готово!</b><br>
        <video src="${videoUrl}" controls playsinline style="width:100%;max-height:220px;margin-top:8px;border-radius:4px;background:#000"></video><br>
        <a href="${videoUrl}" download="vhub-video.mp4" style="color:var(--runway);font-size:11px">⬇ Скачать видео</a>`;
    }

  } catch (e) {
    status.textContent = '⚠ ' + e.message;
    setProgress('❌ Ошибка: ' + e.message);
  }

  btn.disabled = false;
  btn.textContent = '▶ Создать видео';
}

function setProgress(text) {
  const el = document.getElementById('runway-progress-text');
  if (el) el.textContent = text;
  document.getElementById('runway-status').textContent = text.substring(0, 30);
}

function updateRunwayBar() {
  const bar = document.getElementById('runway-bar');
  if (currentAgent && currentAgent.id === 'video') {
    bar.classList.add('visible');
  } else {
    bar.classList.remove('visible');
    document.getElementById('runway-result').classList.remove('visible');
  }
}

