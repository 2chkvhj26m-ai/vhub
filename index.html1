  { id:'strategy', icon:'♟️', short:'Стратег', name:'Стратег', desc:'Стратегия · Рост · 3 года', prompts:['Стратегический обзор','Что мне нужно остановить?','Куда двигаться через 3 года?'], initiative:false, system:`${CONTEXT}\nТы — стратегический советник. Используй SWOT, BCG матрицу, сценарное планирование. Говори правду даже если неудобно.` },
  { id:'risk', icon:'🛡️', short:'Риски', name:'Риск-менеджер', desc:'Угрозы · Защита · Plan B', prompts:['Карта рисков бизнесов','Риск зависимости от поставщика','Что будет если...?'], initiative:false, system:`${CONTEXT}\nТы — директор по рискам. Оценивай по матрице Вероятность × Последствия. Для каждого риска: вероятность, последствия, защита, Plan B.` },
  { id:'cx', icon:'⭐', short:'CX', name:'Клиентский опыт (CX)', desc:'Лояльность · NPS · Удержание', prompts:['Как удержать клиентов СТО?','Программа лояльности MAGUS','Работа с отзывами'], initiative:false, system:`${CONTEXT}\nТы — директор по клиентскому опыту. Повторный клиент в 5 раз дешевле нового. Давай скрипты и шаблоны. Метрики: NPS, Churn Rate, LTV.` },
  { id:'personal', icon:'🧭', short:'Советник', name:'Личный советник', desc:'Баланс · Решения · Энергия', prompts:['Как не выгореть?','Сложное решение','Баланс работа-семья'], initiative:true, initiativePrompt:'Спроси тепло как Валентин себя чувствует сегодня как человек, не как предприниматель. Один вопрос: что сейчас отнимает больше всего энергии?', system:`${CONTEXT}\nТы — личный советник и близкий друг. Помогай принимать решения, предотвращай выгорание. Говори тепло, по-человечески.` },
  {
    id: 'video',
    icon: '🎬',
    short: 'Видео-\nмарк.',
    name: 'Видео-маркетолог',
    desc: 'Сценарии · Психология влияния · Runway AI · Тренды 2026',
    prompts: ['Создай сценарий видео для СТО', 'Сгенерируй 10 хуков для MAGUS', 'Бриф для видеографа'],
    initiative: false,
    system: `${CONTEXT}

Ты — топовый видео-маркетолог мирового уровня. Объединяешь нейромаркетинг, психологию влияния и тренды видеоконтента 2026.

БИЗНЕСЫ ДЛЯ ВИДЕО:
- СТО «Автомаксимум-Плюс» — ремонт авто, Кропивницький
- MAGUS / AURUM ROASTERS — кофейный премиум бренд
- Торнадо — оптовые продукты B2B
- Личный бренд Валентина

ФОРМАТЫ СЦЕНАРИЯ:
🎯 ЦЕЛЬ: [конкретная цель]
🪝 ХУК (0-3 сек): [первые слова]
📖 ИСТОРИЯ (3-30 сек): [развитие]
💡 ЦЕННОСТЬ (30-50 сек): [польза]
⚡ CTA (50-60 сек): [призыв к действию]
🎵 МУЗЫКА: [темп, жанр]
🎨 ВИЗУАЛ: [стиль, цвета]
📱 ПЛАТФОРМА: [TikTok/Reels/YouTube]

ГЕНЕРАЦИЯ ВИДЕО:
Когда создаёшь промпт для Runway — пиши его на английском, детально описывай:
- Что происходит в кадре (руки, движения, объекты)
- Свет (тёплый амбер, студийный, дневной)
- Стиль (UGC, documentary, cinematic)
- Камера (handheld, shallow DOF, close-up)

После создания промпта — скопируй его в поле RUNWAY выше и нажми "Создать видео".

ТРЕНДЫ 2026:
✅ UGC стиль — снятое как обычным человеком
✅ Субтитры на 100% видео
✅ За кулисами — аутентичность важнее полировки
✅ AI-инструменты открыто
✅ Локальный контент

Отвечай структурированно, давай готовые к использованию материалы. Предлагай 2-3 варианта.`
  }
];

// ================================================
// STATE
// ================================================
let currentAgent = null, conversations = {}, attachedFiles = [], isLoading = false, apiKey = '';
let councilMode = false, councilSelectedAgents = [];

// ================================================
// INIT
// ================================================
function getStoredKey() {
  try { return localStorage.getItem('vhub_api_key') || ''; } catch(e) {}
  try { const m = document.cookie.match(/vhub_key=([^;]+)/); return m ? decodeURIComponent(m[1]) : ''; } catch(e) {}
  return '';
}
function storeKey(val) {
  try { localStorage.setItem('vhub_api_key', val); } catch(e) {}
  try { document.cookie = 'vhub_key=' + encodeURIComponent(val) + ';path=/;max-age=31536000'; } catch(e) {}
}
function init() {
  apiKey = getStoredKey();
  if (!apiKey) { document.getElementById('setup-screen').classList.remove('hidden'); }
  else { document.getElementById('setup-screen').classList.add('hidden'); loadConversations(); buildSidebar(); }
}
function saveKey() {
  const val = document.getElementById('api-key-input').value.replace(/\s/g,'');
  if (!val || val.length < 5) { alert('Введи API ключ'); return; }
  apiKey = val; storeKey(val);
  document.getElementById('setup-screen').classList.add('hidden');
  buildSidebar();
}
function resetKey() {
  if (confirm('Сменить API КЛЮЧ?')) {
    try { localStorage.removeItem('vhub_api_key'); } catch(e) {}
    location.reload();
  }
}

// ================================================
// SIDEBAR
// ================================================
function buildSidebar() {
  const sb = document.getElementById('sidebar');
  sb.innerHTML = AGENTS.map(a => {
    const hasDrive = !!DRIVE_CONFIG.folders[a.id];
    const fn = councilMode ? 'toggleCouncilAgent' : 'selectAgent';
    return `<button class="agent-btn${hasDrive?' has-drive':''}" id="btn-${a.id}" onclick="${fn}('${a.id}')">
      <div class="agent-check">✓</div>
      <div class="drive-dot"></div>
      <div class="agent-icon">${a.icon}</div>
      <div class="agent-short">${a.short}</div>
    </button>`;
  }).join('');
}

// ================================================
// COUNCIL
// ================================================
function toggleCouncilMode() {
  councilMode = !councilMode;
  councilSelectedAgents = [];
  const btn = document.getElementById('council-toggle-btn');
  const infoHeader = document.getElementById('council-info-header');
  if (councilMode) {
    btn.classList.add('active'); btn.textContent = '⚡ СОВЕТ ВКЛ';
    infoHeader.classList.add('visible');
    document.getElementById('header-title').textContent = 'РЕЖИМ СОВЕТА';
    currentAgent = null;
    document.getElementById('agent-header').style.display = 'none';
    document.getElementById('input-area').style.display = 'none';
    document.getElementById('drive-bar').classList.remove('visible');
    document.getElementById('runway-bar').classList.remove('visible');
    showCouncilWelcome();
  } else {
    btn.classList.remove('active'); btn.textContent = '⚡ СОВЕТ';
    infoHeader.classList.remove('visible');
    document.getElementById('header-title').textContent = 'ВЫБЕРИ АГЕНТА';
    showWelcome();
  }
  buildSidebar();
}

function toggleCouncilAgent(id) {
  const idx = councilSelectedAgents.indexOf(id);
  const btn = document.getElementById('btn-' + id);
  if (idx === -1) { councilSelectedAgents.push(id); btn.classList.add('council-selected'); }
  else { councilSelectedAgents.splice(idx, 1); btn.classList.remove('council-selected'); }
  updateCouncilUI();
}

function updateCouncilUI() {
  const names = councilSelectedAgents.map(id => { const a = AGENTS.find(x => x.id===id); return a ? a.icon+' '+a.name : ''; }).join(' · ');
  document.getElementById('council-agents-list').textContent = names || 'Выбери агентов в боковой панели';
  document.querySelectorAll('.council-agent-chip').forEach(chip => chip.classList.toggle('selected', councilSelectedAgents.includes(chip.dataset.id)));
  const startBtn = document.getElementById('council-start-btn');
  if (startBtn) startBtn.disabled = councilSelectedAgents.length < 1;
  if (councilSelectedAgents.length >= 1) {
    document.getElementById('agent-header').style.display = 'block';
    document.getElementById('agent-name-display').textContent = '⚡ Совет агентов';
    document.getElementById('agent-desc-display').textContent = names;
    document.getElementById('input-area').style.display = 'flex';
    const msgs = document.getElementById('messages');
    if (msgs.querySelector('.council-welcome')) msgs.innerHTML = '';
  }
}

function showCouncilWelcome() {
  document.getElementById('messages').innerHTML = `<div class="council-welcome">
    <div style="font-size:48px">⚡</div>
    <div class="council-welcome-title">РЕЖИМ СОВЕТА</div>
    <div class="council-welcome-desc">Выбери 2-4 агента которые будут совещаться.</div>
    <div class="council-agents-grid">${AGENTS.map(a=>`<div class="council-agent-chip" data-id="${a.id}" onclick="toggleCouncilAgent('${a.id}')"><span>${a.icon}</span><span>${a.name}</span></div>`).join('')}</div>
    <button class="council-start-btn" id="council-start-btn" disabled onclick="startCouncilChat()">НАЧАТЬ СОВЕТ →</button>
  </div>`;
}

function startCouncilChat() { if (councilSelectedAgents.length < 1) return; updateCouncilUI(); document.getElementById('msg-input').focus(); }

async function sendCouncilMessage(text) {
  const msgs = document.getElementById('messages');
  const userDiv = document.createElement('div');
  userDiv.className = 'msg user'; userDiv.textContent = text; msgs.appendChild(userDiv);
  if (!conversations['council']) conversations['council'] = [];
  const roundReplies = [];
  for (let i = 0; i < councilSelectedAgents.length; i++) {
    const agent = AGENTS.find(a => a.id === councilSelectedAgents[i]);
    if (!agent) continue;
    const typingDiv = document.createElement('div');
    typingDiv.className = 'msg thinking';
    typingDiv.innerHTML = `${agent.icon} <b>${agent.name}</b> думает <span class="dots"><span></span><span></span><span></span></span>`;
    msgs.appendChild(typingDiv); msgs.scrollTop = msgs.scrollHeight;
    try {
      const prevCtx = roundReplies.length > 0 ? '\n\nУже высказались:\n' + roundReplies.map(r=>`${r.name}: ${r.reply}`).join('\n\n') : '';
      const isLast = i === councilSelectedAgents.length - 1 && councilSelectedAgents.length > 1;
      const roleNote = isLast ? '\n\nТы последний. Подведи итог и дай ФИНАЛЬНУЮ рекомендацию.' : '\n\nВыскажи мнение с точки зрения своей экспертизы.';
      const resp = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
        body: JSON.stringify({model:'claude-sonnet-4-6',max_tokens:800,system:agent.system+prevCtx+roleNote,messages:[...(conversations['council']||[]).slice(-8).map(m=>({role:m.role,content:m.content})),{role:'user',content:text}]})
      });
      const data = await resp.json();
      typingDiv.remove();
      if (!data.error) {
        const reply = data.content?.[0]?.text || '';
        roundReplies.push({name:agent.name, reply});
        const replyDiv = document.createElement('div');
        replyDiv.className = 'msg council-msg';
        replyDiv.innerHTML = `<div class="msg-agent-label">${agent.icon} ${agent.name.toUpperCase()}${isLast?' — 🏁 ИТОГ':''}</div>${escHtml(reply)}<button class="speak-btn" onclick="speakMsg(this)" data-text="${reply.replace(/"/g,'&quot;').substring(0,500)}">🔊</button>`;
        msgs.appendChild(replyDiv); msgs.scrollTop = msgs.scrollHeight;
        conversations['council'].push({role:'assistant',content:agent.name+': '+reply,time:now()});
        saveConversations();
      }
    } catch(err) { typingDiv.remove(); addSystemMsg('⚠ Ошибка '+agent.name+': '+err.message); }
  }
  conversations['council'].push({role:'user',content:text,time:now()});
  saveConversations(); msgs.scrollTop = msgs.scrollHeight;
}

// ================================================
// AGENT SELECTION
// ================================================
function selectAgent(id) {
  if (councilMode) { toggleCouncilAgent(id); return; }
  currentAgent = AGENTS.find(a => a.id === id);
  if (!currentAgent) return;
  document.querySelectorAll('.agent-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('btn-' + id).classList.add('active');
  document.getElementById('header-title').textContent = currentAgent.name.toUpperCase();
  document.getElementById('agent-header').style.display = 'block';
  document.getElementById('agent-name-display').textContent = currentAgent.icon + '  ' + currentAgent.name;
  document.getElementById('agent-desc-display').textContent = currentAgent.desc;
  document.getElementById('input-area').style.display = 'flex';
  updateDriveBar();
  updateRunwayBar();
  renderQuickPrompts();
  renderMessages();
  if (currentAgent.initiative && !conversations[currentAgent.id]?.length) setTimeout(() => agentInitiative(), 600);
}

async function agentInitiative() {
  if (!currentAgent?.initiative) return;
  showTyping();
  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
      body: JSON.stringify({model:'claude-sonnet-4-6',max_tokens:1024,system:currentAgent.system,messages:[{role:'user',content:currentAgent.initiativePrompt}]})
    });
    const data = await resp.json();
    hideTyping();
    if (!data.error) {
      const reply = data.content?.[0]?.text || '';
      if (!conversations[currentAgent.id]) conversations[currentAgent.id] = [];
      conversations[currentAgent.id].push({role:'assistant',content:reply,time:now(),initiative:true});
      renderMessages();
    }
  } catch(e) { hideTyping(); }
}

// ================================================
// MESSAGES
// ================================================
function renderQuickPrompts() {
  if (!currentAgent) return;
  const container = document.getElementById('quick-prompts');
  if (conversations[currentAgent.id]?.length > 0) { container.innerHTML = ''; return; }
  container.innerHTML = currentAgent.prompts.map(p=>`<button class="qp" onclick="usePrompt('${p.replace(/'/g,"\\'")}')">${p}</button>`).join('');
}
function usePrompt(text) { document.getElementById('msg-input').value = text; sendMessage(); }

function renderMessages() {
  const container = document.getElementById('messages');
  if (!currentAgent) return;
  const msgs = conversations[currentAgent.id] || [];
  if (msgs.length === 0) {
    container.innerHTML = `<div class="welcome"><div class="welcome-icon">${currentAgent.icon}</div><div class="welcome-name">${currentAgent.name}</div><div class="welcome-desc">${currentAgent.desc}</div><div class="welcome-prompts">${currentAgent.prompts.map(p=>`<button class="welcome-prompt" onclick="usePrompt('${p.replace(/'/g,"\\'")}')">${p} →</button>`).join('')}</div></div>`;
  } else {
    container.innerHTML = msgs.map(m => {
      const initLabel = m.initiative ? `<div class="msg-meta" style="color:var(--green);margin-bottom:4px">◉ ИНИЦИАТИВА АГЕНТА</div>` : '';
      const speakBtn = (m.role==='assistant'||m.initiative) ? `<button class="speak-btn" onclick="speakMsg(this)" data-text="${(m.content||'').replace(/"/g,'&quot;').substring(0,500)}">🔊</button>` : '';
      const time = m.time ? `<div class="msg-meta">${m.time}</div>` : '';
      return `<div class="msg ${m.role}${m.initiative?' initiative':''}">${initLabel}${escHtml(m.content)}${speakBtn}${time}</div>`;
    }).join('');
    container.scrollTop = container.scrollHeight;
  }
}

function showWelcome() {
  document.getElementById('messages').innerHTML = `<div class="welcome"><div class="welcome-icon">◎</div><div class="welcome-name">Добро пожаловать, Валентин</div><div class="welcome-desc">Выбери агента слева чтобы начать работу.</div></div>`;
  document.getElementById('agent-header').style.display = 'none';
  document.getElementById('input-area').style.display = 'none';
  document.getElementById('drive-bar').classList.remove('visible');
  document.getElementById('runway-bar').classList.remove('visible');
}

function escHtml(str) { return (str||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>'); }

function addMsg(role, content) {
  if (!currentAgent) return;
  if (!conversations[currentAgent.id]) conversations[currentAgent.id] = [];
  conversations[currentAgent.id].push({role, content, time:now()});
  saveConversations(); renderMessages();
  if (role==='assistant') autoSpeakText(content);
}
function addSystemMsg(text) {
  const container = document.getElementById('messages');
  const div = document.createElement('div');
  div.className = 'msg system'; div.textContent = text;
  container.appendChild(div); container.scrollTop = container.scrollHeight;
}
function now() { return new Date().toLocaleTimeString('ru',{hour:'2-digit',minute:'2-digit'}); }
function showTyping() {
  const container = document.getElementById('messages');
  const el = document.createElement('div');
  el.className = 'msg thinking'; el.id = 'typing-indicator';
  el.innerHTML = `${currentAgent?.icon||'◎'} думает <span class="dots"><span></span><span></span><span></span></span>`;
  container.appendChild(el); container.scrollTop = container.scrollHeight;
}
function hideTyping() { document.getElementById('typing-indicator')?.remove(); }

// ================================================
// SEND MESSAGE
// ================================================
async function sendMessage() {
  if (isLoading) return;
  if (councilMode && councilSelectedAgents.length >= 1) {
    const input = document.getElementById('msg-input');
    const text = input.value.trim();
    if (!text) return;
    input.value = ''; input.style.height = 'auto';
    isLoading = true; document.getElementById('send-btn').disabled = true;
    await sendCouncilMessage(text);
    isLoading = false; document.getElementById('send-btn').disabled = false;
    return;
  }
  if (!currentAgent) return;
  const input = document.getElementById('msg-input');
  const text = input.value.trim();
  if (!text && attachedFiles.length === 0) return;
  isLoading = true; document.getElementById('send-btn').disabled = true;
  let userContent = text;
  if (attachedFiles.length > 0) userContent += '\n\n[Файлы: ' + attachedFiles.map(f=>f.name).join(', ') + ']';
  input.value = ''; input.style.height = 'auto';
  attachedFiles = []; renderFileBar();
  addMsg('user', userContent);
  showTyping();
  try {
    const history = (conversations[currentAgent.id]||[]).filter(m=>m.role==='user'||m.role==='assistant').slice(-20).map(m=>({role:m.role,content:m.content}));
    const systemWithDrive = currentAgent.system + getDriveContext();
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {'Content-Type':'application/json','x-api-key':apiKey,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},
      body: JSON.stringify({model:'claude-sonnet-4-6',max_tokens:2048,system:systemWithDrive,messages:history})
    });
    const data = await resp.json();
    hideTyping();
    if (data.error) addMsg('system','⚠ Ошибка: '+data.error.message);
    else addMsg('assistant', data.content?.[0]?.text || '(нет ответа)');
  } catch(err) {
    hideTyping();
    addMsg('system','⚠ Ошибка: '+err.message);
  }
  isLoading = false; document.getElementById('send-btn').disabled = false;
}

// ================================================
// UTILS
// ================================================
function handleKey(e) { if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();} }
function autoResize(el) { el.style.height='auto'; el.style.height=Math.min(el.scrollHeight,160)+'px'; }
function clearChat() {
  if (!currentAgent) return;
  if (confirm('Очистить историю чата с '+currentAgent.name+'?')) {
    conversations[currentAgent.id]=[]; saveConversations(); renderMessages(); renderQuickPrompts();
    driveDataCache[currentAgent.id]=null; updateDriveBar();
  }
}
function attachFile(e) { const f=e.target.files[0]; if(!f) return; attachedFiles.push(f); renderFileBar(); e.target.value=''; }
function renderFileBar() {
  document.getElementById('file-bar').innerHTML = attachedFiles.map((f,i)=>`<div class="file-chip">🔗 ${f.name}<button onclick="removeFile(${i})">×</button></div>`).join('');
}
function removeFile(i) { attachedFiles.splice(i,1); renderFileBar(); }

// ================================================
// VOICE
// ================================================
let recognition=null, isRecording=false, currentUtterance=null, autoSpeak=false, selectedVoice=null;

function initVoice() {
  if ('speechSynthesis' in window) {
    const loadVoices = () => {
      const all = speechSynthesis.getVoices();
      const ru = all.filter(v=>v.lang.startsWith('ru')||v.lang.startsWith('uk'));
      const use = ru.length>0?ru:all.slice(0,5);
      const sel = document.getElementById('voice-select');
      if (!sel) return;
      sel.innerHTML = use.map((v,i)=>`<option value="${i}">${v.name.substring(0,20)}</option>`).join('');
      if (use.length>0) selectedVoice=use[0];
    };
    speechSynthesis.onvoiceschanged=loadVoices; loadVoices();
    document.getElementById('voice-settings').classList.add('visible');
  }
  const SR = window.SpeechRecognition||window.webkitSpeechRecognition;
  if (!SR) { document.getElementById('voice-btn').style.display='none'; return; }
  recognition = new SR();
  recognition.lang='ru-RU'; recognition.continuous=false; recognition.interimResults=true;
  recognition.onresult=(e)=>{
    const t=Array.from(e.results).map(r=>r[0].transcript).join('');
    document.getElementById('msg-input').value=t;
    autoResize(document.getElementById('msg-input'));
    if(e.results[e.results.length-1].isFinal){stopRecording();setTimeout(()=>sendMessage(),300);}
  };
  recognition.onerror=()=>stopRecording(); recognition.onend=()=>stopRecording();
}

function toggleVoiceInput() { isRecording?stopRecording():startRecording(); }
function startRecording() {
  if(!recognition) return; isRecording=true;
  const btn=document.getElementById('voice-btn');
  btn.classList.add('recording'); btn.textContent='⏹';
  document.getElementById('msg-input').placeholder='🎤 Говори...';
  recognition.start();
}
function stopRecording() {
  isRecording=false;
  const btn=document.getElementById('voice-btn');
  btn.classList.remove('recording'); btn.textContent='🎤';
  document.getElementById('msg-input').placeholder='Введи сообщение...';
  try{recognition?.stop();}catch(e){}
}
function speakMsg(btn) {
  const text = btn.getAttribute('data-text')||'';
  if(!('speechSynthesis' in window)) return;
  if(currentUtterance&&btn.classList.contains('speaking')){speechSynthesis.cancel();btn.classList.remove('speaking');btn.textContent='🔊';currentUtterance=null;return;}
  speechSynthesis.cancel();
  document.querySelectorAll('.speak-btn.speaking').forEach(b=>{b.classList.remove('speaking');b.textContent='🔊';});
  const u=new SpeechSynthesisUtterance(text); u.lang='ru-RU'; u.rate=0.95; if(selectedVoice) u.voice=selectedVoice;
  btn.classList.add('speaking'); btn.textContent='⏹';
  u.onend=()=>{btn.classList.remove('speaking');btn.textContent='🔊';currentUtterance=null;};
  u.onerror=()=>{btn.classList.remove('speaking');btn.textContent='🔊';currentUtterance=null;};
  currentUtterance=u; speechSynthesis.speak(u);
}
function autoSpeakText(text) {
  if(!autoSpeak||!('speechSynthesis' in window)) return;
  speechSynthesis.cancel();
  const u=new SpeechSynthesisUtterance(text); u.lang='ru-RU'; u.rate=0.95; if(selectedVoice) u.voice=selectedVoice;
  speechSynthesis.speak(u);
}
function toggleAutoSpeak() {
  autoSpeak=!autoSpeak;
  const btn=document.getElementById('autospeak-btn');
  btn.textContent=autoSpeak?'авто-речь ВКЛ':'авто-речь ВЫКЛ'; btn.classList.toggle('on',autoSpeak);
}
function updateVoice() {
  const sel=document.getElementById('voice-select');
  const all=speechSynthesis.getVoices();
  const ru=all.filter(v=>v.lang.startsWith('ru')||v.lang.startsWith('uk'));
  const use=ru.length>0?ru:all.slice(0,5);
  selectedVoice=use[parseInt(sel.value)]||null;
}

// ================================================
// STORAGE
// ================================================
function saveConversations() { try{localStorage.setItem('vhub_conversations',JSON.stringify(conversations));}catch(e){} }
function loadConversations() { try{const d=localStorage.getItem('vhub_conversations');if(d)conversations=JSON.parse(d);}catch(e){conversations={};} }

// START
init();
initVoice();
</script>
</body>
</html>
