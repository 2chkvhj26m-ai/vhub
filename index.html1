<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="V·HUB">
<title>V·HUB — Личный штаб</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a08;
    --surface: #111110;
    --surface2: #1a1a18;
    --border: #2a2a26;
    --gold: #c9a84c;
    --gold-dim: #7a6330;
    --text: #e8e4d8;
    --text-dim: #6b6860;
    --text-mid: #a8a49a;
    --red: #c0392b;
    --green: #27ae60;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  body {
    font-family: 'JetBrains Mono', monospace;
    background: var(--bg);
    color: var(--text);
    height: 100dvh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── SETUP SCREEN ── */
  #setup-screen {
    position: fixed; inset: 0; z-index: 100;
    background: var(--bg);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 32px; padding: 40px;
  }
  #setup-screen.hidden { display: none; }

  .setup-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 56px; font-weight: 300;
    color: var(--gold);
    letter-spacing: 8px;
  }
  .setup-sub {
    color: var(--text-dim); font-size: 11px;
    letter-spacing: 3px; text-transform: uppercase;
    text-align: center; line-height: 1.8;
  }
  .setup-input-wrap { width: 100%; max-width: 420px; }
  .setup-label { font-size: 10px; color: var(--text-dim); letter-spacing: 2px; margin-bottom: 8px; }
  .setup-input {
    width: 100%; padding: 16px 20px;
    background: var(--surface2); border: 1px solid var(--border);
    color: var(--text); font-family: 'JetBrains Mono', monospace;
    font-size: 13px; border-radius: 2px; outline: none;
  }
  .setup-input:focus { border-color: var(--gold-dim); }
  .setup-btn {
    width: 100%; max-width: 420px; padding: 18px;
    background: var(--gold); color: #0a0a08;
    font-family: 'JetBrains Mono', monospace; font-size: 12px;
    letter-spacing: 3px; text-transform: uppercase;
    border: none; cursor: pointer; border-radius: 2px;
    transition: opacity 0.2s;
  }
  .setup-btn:hover { opacity: 0.85; }
  .setup-hint {
    font-size: 10px; color: var(--text-dim); text-align: center;
    max-width: 360px; line-height: 1.9;
  }
  .setup-hint a { color: var(--gold-dim); }

  /* ── HEADER ── */
  header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 20px; height: 56px; min-height: 56px;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
    flex-shrink: 0;
  }
  .logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px; font-weight: 300; color: var(--gold);
    letter-spacing: 4px;
  }
  .agent-title {
    font-size: 10px; color: var(--text-dim); letter-spacing: 2px;
    text-transform: uppercase; text-align: center;
    flex: 1; margin: 0 12px;
  }
  .key-btn {
    background: none; border: 1px solid var(--border);
    color: var(--text-dim); font-family: 'JetBrains Mono', monospace;
    font-size: 9px; letter-spacing: 1px; padding: 6px 10px;
    cursor: pointer; border-radius: 2px;
    transition: border-color 0.2s, color 0.2s;
  }
  .key-btn:hover { border-color: var(--gold-dim); color: var(--gold); }

  /* ── MAIN LAYOUT ── */
  .main {
    display: flex; flex: 1; overflow: hidden;
  }

  /* ── SIDEBAR ── */
  .sidebar {
    width: 72px; min-width: 72px;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex; flex-direction: column;
    overflow-y: auto; padding: 8px 0;
    flex-shrink: 0;
  }
  .sidebar::-webkit-scrollbar { display: none; }

  .agent-btn {
    width: 100%; aspect-ratio: 1;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 4px; cursor: pointer;
    border: none; background: none;
    border-left: 2px solid transparent;
    transition: all 0.15s; padding: 8px 4px;
    position: relative;
  }
  .agent-btn:hover { background: var(--surface2); }
  .agent-btn.active {
    background: var(--surface2);
    border-left-color: var(--gold);
  }
  .agent-icon { font-size: 20px; line-height: 1; }
  .agent-short { font-size: 7px; color: var(--text-dim); letter-spacing: 0.5px; text-align: center; line-height: 1.2; }
  .agent-btn.active .agent-short { color: var(--gold); }

  /* ── CHAT AREA ── */
  .chat-area {
    flex: 1; display: flex; flex-direction: column; overflow: hidden;
  }

  .agent-header {
    padding: 16px 20px 12px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    flex-shrink: 0;
  }
  .agent-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-weight: 400; color: var(--text);
  }
  .agent-desc { font-size: 10px; color: var(--text-dim); margin-top: 2px; letter-spacing: 0.5px; }

  .messages {
    flex: 1; overflow-y: auto; padding: 20px 16px;
    display: flex; flex-direction: column; gap: 16px;
  }
  .messages::-webkit-scrollbar { width: 3px; }
  .messages::-webkit-scrollbar-thumb { background: var(--border); }

  .msg {
    max-width: 85%; padding: 14px 16px;
    border-radius: 2px; font-size: 13px; line-height: 1.7;
  }
  .msg.user {
    background: var(--surface2); border: 1px solid var(--border);
    align-self: flex-end; color: var(--text);
  }
  .msg.assistant {
    background: #16160e; border: 1px solid #2a2820;
    align-self: flex-start; color: var(--text-mid);
    border-left: 2px solid var(--gold-dim);
  }
  .msg.system {
    background: none; border: none;
    color: var(--text-dim); font-size: 11px;
    align-self: center; text-align: center; letter-spacing: 0.5px;
    padding: 4px 0;
  }
  .msg.thinking {
    background: #16160e; border: 1px solid #2a2820;
    align-self: flex-start; color: var(--text-dim);
    border-left: 2px solid var(--gold-dim);
    font-style: italic; font-size: 12px;
  }

  .msg-meta { font-size: 9px; color: var(--text-dim); margin-top: 6px; letter-spacing: 0.5px; }

  /* typing dots */
  .dots span {
    display: inline-block; width: 4px; height: 4px;
    background: var(--gold-dim); border-radius: 50%; margin: 0 2px;
    animation: dot 1.2s infinite;
  }
  .dots span:nth-child(2) { animation-delay: 0.2s; }
  .dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes dot { 0%,80%,100%{opacity:0.2} 40%{opacity:1} }

  /* ── INPUT AREA ── */
  .input-area {
    padding: 12px 16px 20px;
    border-top: 1px solid var(--border);
    background: var(--surface);
    flex-shrink: 0;
    display: flex; flex-direction: column; gap: 8px;
  }

  .file-bar {
    display: flex; gap: 8px; align-items: center; flex-wrap: wrap;
  }
  .file-chip {
    font-size: 10px; color: var(--gold); background: #1a180a;
    border: 1px solid var(--gold-dim); padding: 3px 10px;
    border-radius: 20px; display: flex; align-items: center; gap: 6px;
  }
  .file-chip button { background: none; border: none; color: var(--text-dim); cursor: pointer; font-size: 12px; }

  .input-row { display: flex; gap: 10px; align-items: flex-end; }

  textarea {
    flex: 1; background: var(--surface2);
    border: 1px solid var(--border); color: var(--text);
    font-family: 'JetBrains Mono', monospace; font-size: 13px;
    padding: 12px 14px; border-radius: 2px; resize: none;
    min-height: 44px; max-height: 160px; line-height: 1.5;
    outline: none; transition: border-color 0.2s;
  }
  textarea:focus { border-color: var(--gold-dim); }
  textarea::placeholder { color: var(--text-dim); }

  .send-btn {
    width: 44px; height: 44px; flex-shrink: 0;
    background: var(--gold); border: none; cursor: pointer;
    border-radius: 2px; display: flex; align-items: center; justify-content: center;
    font-size: 18px; transition: opacity 0.2s;
  }
  .send-btn:hover { opacity: 0.85; }
  .send-btn:disabled { opacity: 0.3; cursor: default; }

  .attach-btn {
    width: 44px; height: 44px; flex-shrink: 0;
    background: var(--surface2); border: 1px solid var(--border);
    color: var(--text-dim); cursor: pointer; border-radius: 2px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; transition: border-color 0.2s;
  }
  .attach-btn:hover { border-color: var(--gold-dim); color: var(--gold); }

  .input-hint { font-size: 10px; color: var(--text-dim); text-align: right; }

  /* ── QUICK PROMPTS ── */
  .quick-prompts {
    display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 4px;
  }
  .qp {
    font-size: 10px; color: var(--text-dim);
    border: 1px solid var(--border); padding: 4px 10px;
    border-radius: 20px; cursor: pointer; background: none;
    font-family: 'JetBrains Mono', monospace;
    transition: all 0.15s; white-space: nowrap;
  }
  .qp:hover { border-color: var(--gold-dim); color: var(--gold); }

  /* ── WELCOME ── */
  .welcome {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 16px; padding: 40px 20px; text-align: center;
  }
  .welcome-icon { font-size: 48px; }
  .welcome-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px; color: var(--text); font-weight: 300;
  }
  .welcome-desc { font-size: 11px; color: var(--text-dim); line-height: 1.9; max-width: 340px; }
  .welcome-prompts { display: flex; flex-direction: column; gap: 8px; width: 100%; max-width: 360px; }
  .welcome-prompt {
    background: var(--surface2); border: 1px solid var(--border);
    padding: 12px 16px; border-radius: 2px; cursor: pointer;
    font-size: 12px; color: var(--text-mid); text-align: left;
    font-family: 'JetBrains Mono', monospace;
    transition: border-color 0.15s;
  }
  .welcome-prompt:hover { border-color: var(--gold-dim); color: var(--text); }

  /* ── CLEAR BTN ── */
  .clear-btn {
    background: none; border: none; color: var(--text-dim);
    font-size: 11px; cursor: pointer; letter-spacing: 0.5px;
    padding: 4px 0; font-family: 'JetBrains Mono', monospace;
  }
  .clear-btn:hover { color: var(--red); }

  @media (max-width: 480px) {
    .sidebar { width: 60px; min-width: 60px; }
    .agent-icon { font-size: 18px; }
    .msg { max-width: 92%; font-size: 12px; }
  }
</style>
</head>
<body>

<!-- SETUP SCREEN -->
<div id="setup-screen">
  <div class="setup-logo">V·HUB</div>
  <div class="setup-sub">Личный штаб Валентина<br>9 агентов · Все бизнесы</div>
  <div class="setup-input-wrap">
    <div class="setup-label">ANTHROPIC API KEY</div>
    <input class="setup-input" type="password" id="api-key-input"
      placeholder="sk-ant-api03-..." autocomplete="off" spellcheck="false">
  </div>
  <button class="setup-btn" onclick="saveKey()">ВОЙТИ В СИСТЕМУ →</button>
  <div class="setup-hint">
    Ключ хранится только на твоём устройстве.<br>
    Получить ключ: <a href="https://console.anthropic.com" target="_blank">console.anthropic.com</a>
  </div>
</div>

<!-- HEADER -->
<header>
  <div class="logo">V·HUB</div>
  <div class="agent-title" id="header-title">ВЫБЕРИ АГЕНТА</div>
  <button class="key-btn" onclick="resetKey()">⚙ КЛЮЧ</button>
</header>

<!-- MAIN -->
<div class="main">
  <!-- SIDEBAR -->
  <div class="sidebar" id="sidebar"></div>

  <!-- CHAT -->
  <div class="chat-area">
    <div class="agent-header" id="agent-header" style="display:none">
      <div class="agent-name" id="agent-name-display"></div>
      <div class="agent-desc" id="agent-desc-display"></div>
    </div>

    <div class="messages" id="messages">
      <div class="welcome" id="welcome-screen">
        <div class="welcome-icon">⬡</div>
        <div class="welcome-name">Добро пожаловать, Валентин</div>
        <div class="welcome-desc">Выбери агента слева чтобы начать работу. Каждый агент специализируется на своей области и помнит контекст твоих бизнесов.</div>
      </div>
    </div>

    <!-- INPUT AREA -->
    <div class="input-area" id="input-area" style="display:none">
      <div class="quick-prompts" id="quick-prompts"></div>
      <div class="file-bar" id="file-bar"></div>
      <div class="input-row">
        <button class="attach-btn" onclick="document.getElementById('file-input').click()" title="Прикрепить файл">📎</button>
        <textarea id="msg-input" placeholder="Введи сообщение..." rows="1"
          oninput="autoResize(this)"
          onkeydown="handleKey(event)"></textarea>
        <button class="send-btn" id="send-btn" onclick="sendMessage()">↑</button>
      </div>
      <div style="display:flex;justify-content:space-between;align-items:center">
        <button class="clear-btn" onclick="clearChat()">✕ очистить чат</button>
        <div class="input-hint" id="input-hint">Enter — отправить · Shift+Enter — новая строка</div>
      </div>
    </div>
  </div>
</div>

<input type="file" id="file-input" style="display:none" accept=".txt,.csv,.xlsx,.pdf,.jpg,.png" onchange="attachFile(event)">

<script>
// ══════════════════════════════════════════════
// AGENTS CONFIGURATION
// ══════════════════════════════════════════════
const CONTEXT = `
Ты работаешь с Валентином Шмидтом — предпринимателем из Кропивницкого (Украина), гражданином Германии и Украины.

БИЗНЕСЫ:
1. СТО «Автомаксимум-Плюс» (автосервис) — недавно потерял ключевого мастера-приёмщика (Коля мобилизован), идёт набор.
2. Оптовая компания оптики
3. Оптовая дистрибуция продуктов питания (1С, Telegram-бот с отчётами)
4. Импорт кофе под брендом AURUM ROASTERS (поставщик — Farid, Arabica Trade, Измир)
5. Имущество: 5 га, артезианская скважина 180м, нерабочий завод ЖБИ с ж/д веткой, склады

ТЕКУЩИЕ ПРОЕКТЫ: PWA-приложение для СТО, мультиагентная система, кофейный бренд, аналитика 1С через Telegram.

Отвечай профессионально, кратко, по делу. Язык общения — русский.
`;

const AGENTS = [
  {
    id: 'secretary',
    icon: '🗓',
    short: 'Секре-\nтарь',
    name: 'Секретарь',
    desc: 'Планирование · Напоминания · Расписание · Задачи',
    color: '#c9a84c',
    prompts: ['Составь план на сегодня', 'Приоритизируй мои задачи', 'Составь недельный план'],
    system: `${CONTEXT}
Ты — личный секретарь и планировщик Валентина. Твои задачи:
- Составлять планы дня/недели/месяца
- Помогать приоритизировать задачи по методу Эйзенхауэра
- Напоминать о важных дедлайнах
- Структурировать хаос множества бизнесов в чёткий план
- Предлагать оптимальный порядок действий

Формат ответа: структурированный, с чёткими блоками. Используй ⬡ для задач, ⚡ для срочных, ✓ для выполненных.`
  },
  {
    id: 'finance',
    icon: '📊',
    short: 'Финан-\nсист',
    name: 'Финансовый аналитик',
    desc: 'Анализ · Аудит · Экономика бизнесов',
    color: '#27ae60',
    prompts: ['Анализ рентабельности СТО', 'Оцени экономику кофейного проекта', 'Что проверить на аудите?'],
    system: `${CONTEXT}
Ты — финансовый аналитик, экономист и аудитор Валентина. Твои задачи:
- Анализировать финансовые показатели всех бизнесов
- Находить точки утечки прибыли
- Строить финансовые модели и прогнозы
- Проводить аудит и выявлять риски
- Давать конкретные рекомендации с цифрами

Всегда просй конкретные данные если нужно. Отвечай с расчётами, таблицами, конкретными цифрами.`
  },
  {
    id: 'newbiz',
    icon: '🚀',
    short: 'Новые\nнапр.',
    name: 'Аналитик новых направлений',
    desc: 'Рынки · Возможности · Диверсификация',
    color: '#8e44ad',
    prompts: ['Что делать с заводом ЖБИ?', 'Оцени потенциал скважины', 'Новые рынки для имущества'],
    system: `${CONTEXT}
Ты — аналитик новых бизнес-направлений. Профиль активов Валентина:
- 5 га земли, завод ЖБИ (нерабочий), ж/д ветка, склады
- Артезианская скважина 180м
- Связи в Германии (двойное гражданство)
- Опыт в авто, оптике, продуктах, кофе

Твои задачи:
- Оценивать новые бизнес-идеи (рынок, конкуренция, маржа, риски)
- Искать применение имеющимся активам
- Анализировать тренды (Украина + ЕС)
- Давать оценку 1-10 по потенциалу

Будь честным: если идея слабая — говори прямо.`
  },
  {
    id: 'fitness',
    icon: '💪',
    short: 'Фитнес\nтренер',
    name: 'Фитнес-тренер & Диетолог',
    desc: 'Тренировки · Питание · Здоровье',
    color: '#e74c3c',
    prompts: ['Составь план тренировок', 'Рацион для энергии', 'Как восстановиться при стрессе?'],
    system: `${CONTEXT}
Ты — персональный фитнес-тренер и диетолог Валентина. У него напряжённый график предпринимателя, множество стрессов.

Твои задачи:
- Составлять реалистичные планы тренировок (с учётом занятости)
- Разрабатывать рационы питания
- Давать советы по восстановлению и энергии
- Помогать поддерживать высокий уровень продуктивности через здоровье

Сначала спроси: возраст, вес, цель, сколько времени в неделю на спорт, есть ли ограничения по здоровью.`
  },
  {
    id: 'german',
    icon: '🇩🇪',
    short: 'Немец-\nкий',
    name: 'Преподаватель немецкого',
    desc: 'B1 → C1 · Бизнес-немецкий · Практика',
    color: '#f39c12',
    prompts: ['Урок: деловые переговоры', 'Проверь мой текст на немецком', 'Объясни Konjunktiv II'],
    system: `${CONTEXT}
Ты — преподаватель немецкого языка. Валентин сейчас на уровне B1, цель — C1. У него немецкое гражданство, бизнес-контакты в Германии (импорт кофе, возможно GmbH).

Фокус обучения:
- Деловой немецкий (переписка, переговоры, документы)
- Грамматика уровня B2-C1 (Konjunktiv, сложные конструкции)
- Словарный запас бизнес и юридической сферы
- Разговорная практика

Формат: объясняй правила просто, давай примеры, исправляй ошибки с объяснением. Чередуй упражнения.`
  },
  {
    id: 'auto',
    icon: '🔧',
    short: 'Совет-\nник СТО',
    name: 'Советник по СТО',
    desc: 'Тренды · Выручка · Технологии автосервиса',
    color: '#3498db',
    prompts: ['Тренды в автосервисе 2025', 'Как увеличить средний чек?', 'Что предложить клиентам сейчас?'],
    system: `${CONTEXT}
Ты — бизнес-советник по автосервису. СТО «Автомаксимум-Плюс» в Кропивницком, Украина. Сейчас проблема: ушёл ключевой мастер-приёмщик Коля (мобилизован), идёт разработка PWA для автоматизации приёма.

Твои задачи:
- Отслеживать тренды рынка автосервисов (Украина + мировой)
- Давать конкретные советы по увеличению выручки и среднего чека
- Анализировать новые услуги и технологии
- Помогать с маркетингом и удержанием клиентов
- Советовать по автоматизации процессов

Давай конкретные, применимые рекомендации с цифрами.`
  },
  {
    id: 'food',
    icon: '🛒',
    short: 'Совет-\nник опт.',
    name: 'Советник: оптовые продукты',
    desc: 'Тренды · Новинки · Дистрибуция',
    color: '#1abc9c',
    prompts: ['Тренды в продуктах питания 2025', 'Новые категории для портфеля', 'Как найти новых клиентов?'],
    system: `${CONTEXT}
Ты — советник по оптовой торговле продуктами питания. Валентин работает в дистрибуции продуктов, использует 1С, строит аналитику через Telegram-бот.

Твои задачи:
- Отслеживать тренды FMCG-рынка Украины
- Рекомендовать новые категории и продукты для портфеля
- Советовать по работе с клиентами (удержание, расширение)
- Помогать с ценовой стратегией
- Анализировать сезонность и спрос

Фокус: практические решения для украинского рынка в условиях войны.`
  },
  {
    id: 'marketing',
    icon: '📣',
    short: 'Марке-\nтолог',
    name: 'Маркетолог',
    desc: 'Продвижение · Бренд · Продажи всех бизнесов',
    color: '#e91e8c',
    prompts: ['Стратегия для AURUM ROASTERS', 'Как продвигать СТО в Кропивницком?', 'Контент-план для соцсетей'],
    system: `${CONTEXT}
Ты — маркетолог для всех бизнесов Валентина. Портфель:
- СТО «Автомаксимум-Плюс» (локальный рынок)
- AURUM ROASTERS (кофейный бренд, импорт из Турции)
- Оптовые продукты (B2B)
- Оптика (оптовая)

Твои задачи:
- Разрабатывать маркетинговые стратегии
- Писать контент для соцсетей, OLX, сайтов
- Помогать с позиционированием и брендингом
- Давать советы по digital-маркетингу
- Анализировать конкурентов

Учитывай: Украина, военное время, ограниченный бюджет — нужен максимум отдачи.`
  },
  {
    id: 'supervisor',
    icon: '👁',
    short: 'Супер-\nвайзер',
    name: 'Супервайзер опта',
    desc: 'Контроль команды · Дебиторка · KPI · Маршруты',
    color: '#ff6b35',
    prompts: ['Проверь KPI менеджеров', 'Анализ дебиторской задолженности', 'Кто из клиентов давно не заказывал?'],
    system: `${CONTEXT}
Ты — супервайзер оптового отдела продуктов питания. Задачи:
- Контроль работы менеджеров и торговых агентов (выполнение плана, активность, маршруты)
- Мониторинг дебиторской задолженности (кто задерживает оплату, суммы, сроки)
- Анализ клиентской базы: спящие клиенты, падение заказов, новые возможности
- KPI: выручка на менеджера, средний чек, количество визитов, конверсия
- Контроль остатков и заявок
- Выявление аномалий в ценах и скидках

Формат ответа: конкретные цифры, имена менеджеров/клиентов если известны, чёткие действия. Если данных нет — спроси что загрузить из 1С.`
  },
  {
    id: 'programmer',
    icon: '💻',
    short: 'Програ-\nммист',
    name: 'Программист',
    desc: 'Код · Автоматизация · Внедрение идей',
    color: '#607d8b',
    prompts: ['Помоги с PWA для СТО', 'Напиши скрипт для 1С выгрузки', 'Как настроить Telegram-бот?'],
    system: `${CONTEXT}
Ты — персональный программист Валентина. Текущие проекты:
- PWA для СТО (GitHub Pages, iPad) — приём клиентов, наряд-заказы, AI-сканирование
- Telegram-бот + Python + Claude API для аналитики 1С
- Эта мультиагентная система (V·HUB)

Стек который используется: HTML/CSS/JS, Python, GitHub Pages, Telegram Bot API, Claude API, 1С.

Твои задачи:
- Писать рабочий код (не псевдокод)
- Объяснять технические решения просто
- Помогать с деплоем и настройкой
- Предлагать архитектурные решения
- Дебажить проблемы

Всегда давай полный рабочий код который можно скопировать и запустить.`
  }
];

// ══════════════════════════════════════════════
// STATE
// ══════════════════════════════════════════════
let currentAgent = null;
let conversations = {}; // { agentId: [{role, content}] }
let attachedFiles = [];
let isLoading = false;
let apiKey = '';

// ══════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════
function init() {
  apiKey = localStorage.getItem('vhub_api_key') || '';
  if (!apiKey) {
    document.getElementById('setup-screen').classList.remove('hidden');
  } else {
    document.getElementById('setup-screen').classList.add('hidden');
    buildSidebar();
  }
}

function saveKey() {
  const val = document.getElementById('api-key-input').value.trim();
  if (!val || !val.startsWith('sk-')) {
    alert('Введи корректный API ключ (начинается с sk-)');
    return;
  }
  apiKey = val;
  localStorage.setItem('vhub_api_key', apiKey);
  document.getElementById('setup-screen').classList.add('hidden');
  buildSidebar();
}

function resetKey() {
  if (confirm('Сменить API ключ?')) {
    localStorage.removeItem('vhub_api_key');
    location.reload();
  }
}

function buildSidebar() {
  const sb = document.getElementById('sidebar');
  sb.innerHTML = AGENTS.map(a => `
    <button class="agent-btn" id="btn-${a.id}" onclick="selectAgent('${a.id}')">
      <div class="agent-icon">${a.icon}</div>
      <div class="agent-short">${a.short}</div>
    </button>
  `).join('');
}

// ══════════════════════════════════════════════
// AGENT SELECTION
// ══════════════════════════════════════════════
function selectAgent(id) {
  currentAgent = AGENTS.find(a => a.id === id);
  if (!currentAgent) return;

  // sidebar active state
  document.querySelectorAll('.agent-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('btn-' + id).classList.add('active');

  // header
  document.getElementById('header-title').textContent = currentAgent.name.toUpperCase();
  document.getElementById('agent-header').style.display = 'block';
  document.getElementById('agent-name-display').textContent = currentAgent.icon + '  ' + currentAgent.name;
  document.getElementById('agent-desc-display').textContent = currentAgent.desc;

  // input area
  document.getElementById('input-area').style.display = 'flex';

  // quick prompts
  renderQuickPrompts();

  // render messages
  renderMessages();
}

function renderQuickPrompts() {
  if (!currentAgent) return;
  const container = document.getElementById('quick-prompts');
  if (conversations[currentAgent.id]?.length > 0) {
    container.innerHTML = '';
    return;
  }
  container.innerHTML = currentAgent.prompts.map(p =>
    `<button class="qp" onclick="usePrompt('${p.replace(/'/g, "\\'")}')">${p}</button>`
  ).join('');
}

function usePrompt(text) {
  document.getElementById('msg-input').value = text;
  sendMessage();
}

// ══════════════════════════════════════════════
// MESSAGES
// ══════════════════════════════════════════════
function renderMessages() {
  const container = document.getElementById('messages');
  const welcome = document.getElementById('welcome-screen');

  if (!currentAgent) return;

  const msgs = conversations[currentAgent.id] || [];

  if (msgs.length === 0) {
    container.innerHTML = `
      <div class="welcome" id="welcome-screen">
        <div class="welcome-icon">${currentAgent.icon}</div>
        <div class="welcome-name">${currentAgent.name}</div>
        <div class="welcome-desc">${currentAgent.desc}</div>
        <div class="welcome-prompts">
          ${currentAgent.prompts.map(p => `
            <button class="welcome-prompt" onclick="usePrompt('${p.replace(/'/g, "\\'")}')">${p} →</button>
          `).join('')}
        </div>
      </div>
    `;
  } else {
    container.innerHTML = msgs.map(m => {
      const time = m.time ? `<div class="msg-meta">${m.time}</div>` : '';
      return `<div class="msg ${m.role}">${escHtml(m.content)}${time}</div>`;
    }).join('');
    container.scrollTop = container.scrollHeight;
  }
}

function escHtml(str) {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/\n/g, '<br>');
}

function addMsg(role, content) {
  if (!currentAgent) return;
  if (!conversations[currentAgent.id]) conversations[currentAgent.id] = [];
  conversations[currentAgent.id].push({
    role,
    content,
    time: new Date().toLocaleTimeString('ru', {hour:'2-digit', minute:'2-digit'})
  });
  renderMessages();
  renderQuickPrompts();
}

function showTyping() {
  const container = document.getElementById('messages');
  const el = document.createElement('div');
  el.className = 'msg thinking';
  el.id = 'typing-indicator';
  el.innerHTML = `${currentAgent.icon} думает <span class="dots"><span></span><span></span><span></span></span>`;
  container.appendChild(el);
  container.scrollTop = container.scrollHeight;
}

function hideTyping() {
  const el = document.getElementById('typing-indicator');
  if (el) el.remove();
}

// ══════════════════════════════════════════════
// SEND MESSAGE
// ══════════════════════════════════════════════
async function sendMessage() {
  if (!currentAgent || isLoading) return;
  const input = document.getElementById('msg-input');
  const text = input.value.trim();
  if (!text && attachedFiles.length === 0) return;

  isLoading = true;
  document.getElementById('send-btn').disabled = true;

  // Build user content
  let userContent = text;
  if (attachedFiles.length > 0) {
    userContent += '\n\n[Прикреплённые файлы: ' + attachedFiles.map(f => f.name).join(', ') + ']';
  }

  input.value = '';
  input.style.height = 'auto';
  attachedFiles = [];
  renderFileBar();

  addMsg('user', userContent);
  showTyping();

  try {
    const history = (conversations[currentAgent.id] || [])
      .filter(m => m.role === 'user' || m.role === 'assistant')
      .slice(-20)
      .map(m => ({ role: m.role, content: m.content }));

    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-5',
        max_tokens: 2048,
        system: currentAgent.system,
        messages: history
      })
    });

    const data = await response.json();
    hideTyping();

    if (data.error) {
      addMsg('system', '⚠ Ошибка: ' + data.error.message);
    } else {
      const reply = data.content?.[0]?.text || '(нет ответа)';
      addMsg('assistant', reply);
    }
  } catch (err) {
    hideTyping();
    addMsg('system', '⚠ Ошибка соединения: ' + err.message);
  }

  isLoading = false;
  document.getElementById('send-btn').disabled = false;
}

// ══════════════════════════════════════════════
// UTILS
// ══════════════════════════════════════════════
function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 160) + 'px';
}

function clearChat() {
  if (!currentAgent) return;
  if (confirm('Очистить историю чата с ' + currentAgent.name + '?')) {
    conversations[currentAgent.id] = [];
    renderMessages();
    renderQuickPrompts();
  }
}

function attachFile(e) {
  const file = e.target.files[0];
  if (!file) return;
  attachedFiles.push(file);
  renderFileBar();
  e.target.value = '';
}

function renderFileBar() {
  const bar = document.getElementById('file-bar');
  bar.innerHTML = attachedFiles.map((f, i) => `
    <div class="file-chip">
      📎 ${f.name}
      <button onclick="removeFile(${i})">×</button>
    </div>
  `).join('');
}

function removeFile(i) {
  attachedFiles.splice(i, 1);
  renderFileBar();
}

// START
init();
</script>
</body>
</html>
