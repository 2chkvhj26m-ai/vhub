<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="V·HUB">
<title>V·HUB — Личный штаб </title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0a08;
    --surface: #111110;
    --surface2: #1a1a18;
    --border: #2a2a26;
    --gold: #c9a84c;
    --gold-dim: #7a6330;
    --text: #e8e4d8;
    --text-dim: #6b6860;
    --text-mid: #a8a49a;
    --red: #c0392b;
    --green: #27ae60;
    --council: #8b5cf6;
    --council-dim: #4c1d95;
    --drive: #1a73e8;
    --runway: #ff4757;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

  body {
    font-family: 'JetBrains Mono', monospace;
    background: var(--bg);
    color: var(--text);
    height: 100dvh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* SETUP SCREEN */
  #setup-screen {
    position: fixed; inset: 0; z-index: 100;
    background: var(--bg);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 32px; padding: 40px;
  }
  #setup-screen.hidden { display: none !important; }
  .setup-logo { font-family: 'Cormorant Garamond', serif; font-size: 56px; font-weight: 300; color: var(--gold); letter-spacing: 8px; }
  .setup-sub { color: var(--text-dim); font-size: 11px; letter-spacing: 3px; text-transform: uppercase; text-align: center; line-height: 1.8; }
  .setup-input-wrap { width: 100%; max-width: 420px; }
  .setup-label { font-size: 10px; color: var(--text-dim); letter-spacing: 2px; margin-bottom: 8px; }
  .setup-input { width: 100%; padding: 16px 20px; background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: 'JetBrains Mono', monospace; font-size: 13px; border-radius: 2px; outline: none; }
  .setup-input:focus { border-color: var(--gold-dim); }
  .setup-btn { width: 100%; max-width: 420px; padding: 18px; background: var(--gold); color: #0a0a08; font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: 3px; text-transform: uppercase; border: none; cursor: pointer; border-radius: 2px; }
  .setup-hint { font-size: 10px; color: var(--text-dim); text-align: center; max-width: 360px; line-height: 1.9; }
  .setup-hint a { color: var(--gold-dim); }

  /* HEADER */
  header { display: flex; align-items: center; justify-content: space-between; padding: 0 20px; height: 56px; min-height: 56px; border-bottom: 1px solid var(--border); background: var(--bg); flex-shrink: 0; gap: 8px; }
  .logo { font-family: 'Cormorant Garamond', serif; font-size: 24px; font-weight: 300; color: var(--gold); letter-spacing: 4px; }
  .agent-title { font-size: 10px; color: var(--text-dim); letter-spacing: 2px; text-transform: uppercase; text-align: center; flex: 1; margin: 0 12px; }
  .council-header-btn { background: none; border: 1px solid var(--council-dim); color: var(--council); font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 1px; padding: 5px 9px; cursor: pointer; border-radius: 2px; white-space: nowrap; }
  .council-header-btn.active { background: var(--council); color: #0a0a08; border-color: var(--council); }
  .key-btn { background: none; border: 1px solid var(--border); color: var(--text-dim); font-family: 'JetBrains Mono', monospace; font-size: 9px; letter-spacing: 1px; padding: 6px 10px; cursor: pointer; border-radius: 2px; }

  /* LAYOUT */
  .main { display: flex; flex: 1; overflow: hidden; }

  /* SIDEBAR */
  .sidebar { width: 72px; min-width: 72px; background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; overflow-y: auto; padding: 8px 0; flex-shrink: 0; }
  .sidebar::-webkit-scrollbar { display: none; }
  .agent-btn { width: 100%; aspect-ratio: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; cursor: pointer; border: none; background: none; border-left: 2px solid transparent; padding: 8px 4px; position: relative; }
  .agent-btn:hover { background: var(--surface2); }
  .agent-btn.active { background: var(--surface2); border-left-color: var(--gold); }
  .agent-icon { font-size: 20px; line-height: 1; }
  .agent-short { font-size: 7px; color: var(--text-dim); letter-spacing: 0.5px; text-align: center; line-height: 1.2; }
  .agent-btn.active .agent-short { color: var(--gold); }
  .agent-check { position: absolute; top: 4px; right: 4px; width: 14px; height: 14px; background: var(--council); border-radius: 50%; display: none; align-items: center; justify-content: center; font-size: 8px; color: #fff; }
  .agent-btn.council-selected .agent-check { display: flex; }
  .agent-btn.council-selected { background: rgba(139,92,246,0.1); border-left-color: var(--council); }
  .drive-dot { position: absolute; bottom: 4px; right: 4px; width: 6px; height: 6px; background: var(--drive); border-radius: 50%; display: none; }
  .agent-btn.has-drive .drive-dot { display: block; }

  /* CHAT AREA */
  .chat-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
  .agent-header { padding: 16px 20px 12px; border-bottom: 1px solid var(--border); background: var(--surface); flex-shrink: 0; }
  .agent-name { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 400; color: var(--text); }
  .agent-desc { font-size: 10px; color: var(--text-dim); margin-top: 2px; }

  /* DRIVE BAR */
  .drive-bar { display: none; align-items: center; gap: 10px; padding: 8px 20px; background: rgba(26,115,232,0.06); border-bottom: 1px solid rgba(26,115,232,0.15); flex-shrink: 0; }
  .drive-bar.visible { display: flex; }
  .drive-bar-label { font-size: 10px; color: var(--drive); letter-spacing: 1px; flex: 1; }
  .drive-load-btn { font-size: 10px; color: var(--drive); background: none; border: 1px solid rgba(26,115,232,0.4); padding: 4px 10px; border-radius: 2px; cursor: pointer; font-family: 'JetBrains Mono', monospace; white-space: nowrap; }
  .drive-load-btn:disabled { opacity: 0.4; cursor: default; }
  .drive-status { font-size: 10px; color: var(--text-dim); }

  /* RUNWAY BAR */
  .runway-bar { display: none; flex-direction: column; gap: 8px; padding: 10px 20px; background: rgba(255,71,87,0.06); border-bottom: 1px solid rgba(255,71,87,0.2); flex-shrink: 0; }
  .runway-bar.visible { display: flex; }
  .runway-bar-top { display: flex; align-items: center; gap: 10px; }
  .runway-bar-label { font-size: 10px; color: var(--runway); letter-spacing: 1px; flex: 1; }
  .runway-status { font-size: 10px; color: var(--text-dim); }
  .runway-generate-btn { font-size: 10px; color: #fff; background: var(--runway); border: none; padding: 6px 14px; border-radius: 2px; cursor: pointer; font-family: 'JetBrains Mono', monospace; white-space: nowrap; }
  .runway-generate-btn:disabled { opacity: 0.4; cursor: default; }
  .runway-prompt-input { width: 100%; padding: 8px 12px; background: var(--surface2); border: 1px solid rgba(255,71,87,0.3); color: var(--text); font-family: 'JetBrains Mono', monospace; font-size: 11px; border-radius: 2px; outline: none; resize: none; height: 60px; }
  .runway-prompt-input:focus { border-color: var(--runway); }

  /* RUNWAY VIDEO RESULT */
  .runway-video-result { display: none; flex-direction: column; gap: 8px; padding: 10px 20px; background: rgba(255,71,87,0.04); border-bottom: 1px solid rgba(255,71,87,0.15); flex-shrink: 0; }
  .runway-video-result.visible { display: flex; }
  .runway-video-result video { width: 100%; max-height: 220px; border-radius: 4px; background: #000; }
  .runway-download-btn { font-size: 10px; color: var(--runway); background: none; border: 1px solid var(--runway); padding: 6px 14px; border-radius: 2px; cursor: pointer; font-family: 'JetBrains Mono', monospace; text-align: center; text-decoration: none; display: block; }
  .runway-progress { font-size: 10px; color: var(--text-dim); background: var(--surface2); padding: 8px 12px; border-radius: 2px; border-left: 2px solid var(--runway); }

  /* COUNCIL */
  .council-header { padding: 12px 20px; border-bottom: 1px solid var(--border); background: rgba(139,92,246,0.05); flex-shrink: 0; display: none; }
  .council-header.visible { display: block; }
  .council-header-title { font-size: 11px; color: var(--council); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 4px; }
  .council-agents-list { font-size: 10px; color: var(--text-dim); }

  /* MESSAGES */
  .messages { flex: 1; overflow-y: auto; padding: 20px 16px; display: flex; flex-direction: column; gap: 16px; }
  .messages::-webkit-scrollbar { width: 3px; }
  .messages::-webkit-scrollbar-thumb { background: var(--border); }

  .msg { max-width: 85%; padding: 14px 16px; border-radius: 2px; font-size: 13px; line-height: 1.7; }
  .msg.user { background: var(--surface2); border: 1px solid var(--border); align-self: flex-end; color: var(--text); }
  .msg.assistant { background: #16160e; border: 1px solid #2a2820; align-self: flex-start; color: var(--text-mid); border-left: 2px solid var(--gold-dim); }
  .msg.council-msg { background: #120f1a; border: 1px solid #2d1f4a; align-self: flex-start; color: var(--text-mid); border-left: 2px solid var(--council); }
  .msg.system { background: none; border: none; color: var(--text-dim); font-size: 11px; align-self: center; text-align: center; padding: 4px 0; }
  .msg.initiative { background: #0e1410; border: 1px solid #1a2d1e; align-self: flex-start; color: var(--text-mid); border-left: 2px solid var(--green); }
  .msg.thinking { background: #16160e; border: 1px solid #2a2820; align-self: flex-start; color: var(--text-dim); border-left: 2px solid var(--gold-dim); font-style: italic; font-size: 12px; }
  .msg.drive-msg { background: #0a0f1a; border: 1px solid #1a2d4a; align-self: flex-start; color: var(--text-dim); border-left: 2px solid var(--drive); font-size: 11px; }
  .msg.video-msg { background: #0f0a0a; border: 1px solid #3a1a1a; align-self: flex-start; color: var(--text-mid); border-left: 2px solid var(--runway); }
  .msg-meta { font-size: 9px; color: var(--text-dim); margin-top: 6px; }
  .msg-agent-label { font-size: 9px; color: var(--council); letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px; }

  .dots span { display: inline-block; width: 4px; height: 4px; background: var(--gold-dim); border-radius: 50%; margin: 0 2px; animation: dot 1.2s infinite; }
  .dots span:nth-child(2) { animation-delay: 0.2s; }
  .dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes dot { 0%,80%,100%{opacity:0.2} 40%{opacity:1} }

  /* INPUT */
  .input-area { padding: 12px 16px 20px; border-top: 1px solid var(--border); background: var(--surface); flex-shrink: 0; display: flex; flex-direction: column; gap: 8px; }
  .file-bar { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
  .file-chip { font-size: 10px; color: var(--gold); background: #1a180a; border: 1px solid var(--gold-dim); padding: 3px 10px; border-radius: 20px; display: flex; align-items: center; gap: 6px; }
  .file-chip button { background: none; border: none; color: var(--text-dim); cursor: pointer; font-size: 12px; }
  .input-row { display: flex; gap: 10px; align-items: flex-end; }
  textarea { flex: 1; background: var(--surface2); border: 1px solid var(--border); color: var(--text); font-family: 'JetBrains Mono', monospace; font-size: 13px; padding: 12px 14px; border-radius: 2px; resize: none; min-height: 44px; max-height: 160px; line-height: 1.5; outline: none; }
  textarea:focus { border-color: var(--gold-dim); }
  textarea::placeholder { color: var(--text-dim); }
  .send-btn { width: 44px; height: 44px; flex-shrink: 0; background: var(--gold); border: none; cursor: pointer; border-radius: 2px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
  .send-btn:disabled { opacity: 0.3; cursor: default; }
  .attach-btn { width: 44px; height: 44px; flex-shrink: 0; background: var(--surface2); border: 1px solid var(--border); color: var(--text-dim); cursor: pointer; border-radius: 2px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
  .voice-btn { width: 44px; height: 44px; flex-shrink: 0; background: var(--surface2); border: 1px solid var(--border); color: var(--text-dim); cursor: pointer; border-radius: 2px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
  .voice-btn.recording { background: rgba(192,57,43,0.15); border-color: var(--red); color: var(--red); animation: pulse-rec 1s infinite; }
  @keyframes pulse-rec { 0%,100%{opacity:1} 50%{opacity:0.5} }
  .input-bottom { display: flex; justify-content: space-between; align-items: center; }
  .clear-btn { background: none; border: none; color: var(--text-dim); font-size: 11px; cursor: pointer; padding: 4px 0; font-family: 'JetBrains Mono', monospace; }
  .clear-btn:hover { color: var(--red); }
  .input-hint { font-size: 10px; color: var(--text-dim); }
  .quick-prompts { display: flex; gap: 8px; flex-wrap: wrap; }
  .qp { font-size: 10px; color: var(--text-dim); border: 1px solid var(--border); padding: 4px 10px; border-radius: 20px; cursor: pointer; background: none; font-family: 'JetBrains Mono', monospace; white-space: nowrap; }
  .qp:hover { border-color: var(--gold-dim); color: var(--gold); }
  .voice-settings { display: none; gap: 8px; align-items: center; flex-wrap: wrap; }
  .voice-settings.visible { display: flex; }
  .voice-settings select { background: var(--surface2); border: 1px solid var(--border); color: var(--text-dim); font-family: 'JetBrains Mono', monospace; font-size: 10px; padding: 4px 8px; border-radius: 2px; outline: none; }
  .voice-toggle { font-size: 10px; color: var(--text-dim); cursor: pointer; background: none; border: 1px solid var(--border); padding: 3px 8px; border-radius: 2px; font-family: 'JetBrains Mono', monospace; }
  .voice-toggle.on { border-color: var(--gold); color: var(--gold); }
  .speak-btn { background: none; border: none; color: var(--text-dim); cursor: pointer; font-size: 14px; padding: 2px 6px; border-radius: 2px; font-family: 'JetBrains Mono', monospace; }
  .speak-btn:hover { color: var(--gold); }
  .speak-btn.speaking { color: var(--gold); animation: pulse-rec 1s infinite; }

  /* WELCOME */
  .welcome { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; padding: 40px 20px; text-align: center; }
  .welcome-icon { font-size: 48px; }
  .welcome-name { font-family: 'Cormorant Garamond', serif; font-size: 28px; color: var(--text); font-weight: 300; }
  .welcome-desc { font-size: 11px; color: var(--text-dim); line-height: 1.9; max-width: 340px; }
  .welcome-prompts { display: flex; flex-direction: column; gap: 8px; width: 100%; max-width: 360px; }
  .welcome-prompt { background: var(--surface2); border: 1px solid var(--border); padding: 12px 16px; border-radius: 2px; cursor: pointer; font-size: 12px; color: var(--text-mid); text-align: left; font-family: 'JetBrains Mono', monospace; }
  .welcome-prompt:hover { border-color: var(--gold-dim); color: var(--text); }

  /* COUNCIL WELCOME */
  .council-welcome { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20px; padding: 40px 20px; text-align: center; }
  .council-welcome-title { font-family: 'Cormorant Garamond', serif; font-size: 26px; color: var(--council); font-weight: 300; }
  .council-welcome-desc { font-size: 11px; color: var(--text-dim); line-height: 1.9; max-width: 380px; }
  .council-agents-grid { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; max-width: 360px; }
  .council-agent-chip { display: flex; align-items: center; gap: 6px; background: var(--surface2); border: 1px solid var(--border); padding: 6px 12px; border-radius: 20px; cursor: pointer; }
  .council-agent-chip span { font-size: 10px; color: var(--text-dim); font-family: 'JetBrains Mono', monospace; }
  .council-agent-chip.selected { border-color: var(--council); background: rgba(139,92,246,0.1); }
  .council-agent-chip.selected span { color: var(--council); }
  .council-start-btn { padding: 14px 32px; background: var(--council); color: #fff; border: none; cursor: pointer; font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; border-radius: 2px; }
  .council-start-btn:disabled { opacity: 0.3; cursor: default; }

  @media (max-width: 480px) {
    .sidebar { width: 60px; min-width: 60px; }
    .agent-icon { font-size: 18px; }
    .msg { max-width: 92%; font-size: 12px; }
  }
</style>
</head>
<body>

<!-- SETUP -->
<div id="setup-screen">
  <div class="setup-logo">V·HUB</div>
  <div class="setup-sub">Личный штаб Валентина<br>16 агентов · Все бизнесы</div>
  <div class="setup-input-wrap">
    <div class="setup-label">ANTHROPIC API KEY</div>
    <input class="setup-input" type="text" id="api-key-input" placeholder="sk-ant-api03-..." autocomplete="off" spellcheck="false" onkeydown="if(event.key==='Enter')saveKey()">
  </div>
  <button class="setup-btn" onclick="saveKey()">ВОЙТИ В СИСТЕМУ →</button>
  <div class="setup-hint">Ключ хранится только на твоём устройстве.<br><a href="https://console.anthropic.com" target="_blank">console.anthropic.com</a></div>
</div>

<!-- HEADER -->
<header>
  <div class="logo">V·HUB</div>
  <div class="agent-title" id="header-title">ВЫБЕРИ АГЕНТА</div>
  <button class="council-header-btn" id="council-toggle-btn" onclick="toggleCouncilMode()">⚡ СОВЕТ</button>
  <button class="key-btn" onclick="resetKey()">⊘ КЛЮЧ</button>
</header>

<div class="main">
  <div class="sidebar" id="sidebar"></div>
  <div class="chat-area">
    <div class="agent-header" id="agent-header" style="display:none">
      <div class="agent-name" id="agent-name-display"></div>
      <div class="agent-desc" id="agent-desc-display"></div>
    </div>

    <!-- DRIVE BAR -->
    <div class="drive-bar" id="drive-bar">
      <div class="drive-bar-label" id="drive-bar-label">📂 Google Drive</div>
      <div class="drive-status" id="drive-status"></div>
      <button class="drive-load-btn" id="drive-load-btn" onclick="loadDriveData()">↓ Загрузить данные</button>
    </div>

    <!-- RUNWAY BAR -->
    <div class="runway-bar" id="runway-bar">
      <div class="runway-bar-top">
        <div class="runway-bar-label">🎬 RUNWAY — Генерация видео</div>
        <div class="runway-status" id="runway-status">готов</div>
        <button class="runway-generate-btn" id="runway-btn" onclick="generateRunwayVideo()">▶ Создать видео</button>
      </div>
      <textarea class="runway-prompt-input" id="runway-prompt" placeholder="Опиши сцену или скопируй промпт от агента..."></textarea>
    </div>
    <div class="runway-video-result" id="runway-result">
      <video id="runway-video" controls playsinline></video>
      <a class="runway-download-btn" id="runway-download" download="vhub-video.mp4">⬇ Скачать видео</a>
    </div>

    <div class="council-header" id="council-info-header">
      <div class="council-header-title">⚡ РЕЖИМ СОВЕТА</div>
      <div class="council-agents-list" id="council-agents-list">Выбери агентов в боковой панели</div>
    </div>

    <div class="messages" id="messages">
      <div class="welcome" id="welcome-screen">
        <div class="welcome-icon">◎</div>
        <div class="welcome-name">Добро пожаловать, Валентин</div>
        <div class="welcome-desc">Выбери агента слева чтобы начать работу.</div>
      </div>
    </div>

    <div class="input-area" id="input-area" style="display:none">
      <div class="quick-prompts" id="quick-prompts"></div>
      <div class="file-bar" id="file-bar"></div>
      <div class="input-row">
        <button class="attach-btn" onclick="document.getElementById('file-input').click()">🔗</button>
        <button class="voice-btn" id="voice-btn" onclick="toggleVoiceInput()">🎤</button>
        <textarea id="msg-input" placeholder="Введи сообщение..." rows="1" oninput="autoResize(this)" onkeydown="handleKey(event)"></textarea>
        <button class="send-btn" id="send-btn" onclick="sendMessage()">↑</button>
      </div>
      <div class="voice-settings" id="voice-settings">
        <span style="font-size:10px;color:var(--text-dim)">🔊</span>
        <select id="voice-select" onchange="updateVoice()"></select>
        <button class="voice-toggle" id="autospeak-btn" onclick="toggleAutoSpeak()">авто-речь ВЫКЛ</button>
      </div>
      <div class="input-bottom">
        <button class="clear-btn" onclick="clearChat()">× очистить чат</button>
        <div class="input-hint" id="input-hint">Enter — отправить · Shift+Enter — новая строка</div>
      </div>
    </div>
  </div>
</div>

<input type="file" id="file-input" style="display:none" accept=".txt,.csv,.xlsx,.pdf,.jpg,.png" onchange="attachFile(event)">

<script>
// ================================================
// CONFIG
// ================================================
const RUNWAY_PROXY = 'https://runway-proxy.vshmidt73.workers.dev';
const RUNWAY_API_KEY = 'key_72bafff622641aefab95f44125c72d7e56242990489b47d9a2fb9820e9cd76f5ab17ab1fea30ef697d0f76d16057c12dd72639b7df92bd0a66dd8da8899e0d76';

const DRIVE_CONFIG = {
  credentials: {
    type: 'service_account',
